  "duaSuhoorTitle": "Saharlik duosi (Niyat)",
  "duaSuhoorArabic": "نَوَيْتُ أَنْ أَصُومَ صَوْمَ شَهْرِ رَمَضَانَ مِنَ الْفَجْرِ إِلَى الْمَغْرِبِ خَالِصًا لِلَّهِ تَعَالَى",
  "duaSuhoorTranslit": "Navaytu an asuma sovma shahri ramazona minal fajri ilal mag'ribi xolisan lillahi ta'ala.",
  "duaSuhoorTransl": "Ramazon oyining ro'zasini tongdan kun botguniga qadar xolis Alloh taolo uchun tutishni niyat qildim.",
  "duaSuhoorTrans": "Navaytu an asuma sovma shahri ramazona minal fajri ilal mag'ribi xolisan lillahi ta'ala",
  "duaSuhoorTranslate": "Ertangi Ramazon oyining ro'zasini xolis Alloh taolo uchun tutishni niyat qildim.",

  "duaIftarTitle": "Iftorlik duosi",
  "duaIftarArabic": "اللَّهُمَّ اِنِّى لَكَ صُمْتُ وَبِكَ امَنْتُ وَعَليْكَ تَوَكَّلْتُ وَعَلى رِزْقِكَ اَفْطَرْتُ",
  "duaIftarTranslit": "Allohumma inni laka sumtu va bika amantu va 'alayka tavakkaltu va 'ala rizqika aftortu.",
  "duaIftarTransl": "Yo Alloh, Sen uchun ro'za tutdim, Senga iymon keltirdim, Senga tavakkal qildim va Sen bergan rizq bilan iftor qildim.",
  "duaIftarTrans": "Zahabaz-zama'u vabtallatil-'uruqu va sabatal-ajru in sha'Alloh",
  "duaIftarTranslate": "Chanqoq bosildi, tomirlar ho'llandi va Alloh xohlasa, ajr sobit bo'ldi.",

  "dua_qadr_title": "Qadr kechasi duosi",
  "dua_qadr_ar": "اللَّهُمَّ إِنَّكَ عَفُوٌّ تُحِبُّ الْعَفْوَ فَاعْفُ عَنِّي",
  "dua_qadr_trans": "Allohumma innaka 'afuvvun tuhibbul-'afva fa'fu 'anni",
  "dua_qadr_text": "Yo Alloh, albatta, Sen Kechiruvchisan, kechirishni yaxshi ko'rasan, meni kechir!",

  "dua_kursi_title": "Oyatul Kursiy",
  "dua_kursi_ar": "اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَّهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَن ذَا الَّذِي يَشْفَعُ عِندَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِّنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ",
  "dua_kursi_trans": "Allohu la ilaha illa Huval-Hayyul-Qayyum, la ta'xuzuhu sinatuv-vala navm...",
  "dua_kursi_text": "Alloh — Undan o'zga iloh yo'q, U Tirik, Abadiydir. Uni mudroq ham, uyqu ham olmaydi...",

  "dua_istighfar_title": "Sayyidul Istig'for",
  "dua_istighfar_ar": "اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَهَ إِلَّا أَنْتَ خَلَقْتَنِي وَأَنَا عَبْدُكَ وَأَنَا عَلَى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطَعْتُ أَعُوذُ بِكَ مِنْ شَرِّ مَا صَنَعْتُ أَبُوءُ لَكَ بِنِعْمَتِكَ عَلَيَّ وَأَبُوءُ بِذَنْبِي فَاغْفِرْ لِي فَإِنَّهُ لَا يَغْفِرُ الذُّنُوبَ إِلَّا أَنْتَ",
  "dua_istighfar_trans": "Allohumma Anta Robbi la ilaha illa Anta, xalaqtani va ana 'abduka...",
  "dua_istighfar_text": "Yo Alloh, Sen mening Robbimsan! Sendan o'zga iloh yo'q. Sen meni yaratding, men Sening qulingman...",

  "dua_sadness_title": "G'am va tashvishdan duo",
  "dua_sadness_ar": "اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْهَمِّ وَالْحَزَنِ",
  "dua_sadness_trans": "Allohumma inni a'uzu bika minal-hammi val-hazan",
  "dua_sadness_text": "Yo Alloh, albatta, men Sendan g'am va tashvishdan panoh tilayman.",

  "dua_morning_title": "Kunlik himoya duosi",
  "dua_morning_ar": "بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ",
  "dua_morning_trans": "Bismillahillazi la yadurru ma'asmihi shay'un fil-ardi va la fis-sama'i va huvas-Sami'ul-'Alim",
  "dua_morning_text": "Allohning ismi bilan boshlaymanki, Uning ismi bilan yeru osmonda biror narsa zarar yetkaza olmas. U Eshituvchi va Biluvchidir!",
