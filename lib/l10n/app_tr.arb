  "quote1_ar": "يَا أَيُّهَا الَّذِينَ آمَنُوا كُتِبَ عَلَيْكُمُ الصِّيَامُ كَمَا كُتِبَ عَلَى الَّذِينَ مِن قَبْلِكُمْ لَعَلَّكُمْ تَتَّقُونَ",
  "quote1_text": "Ey iman edenler! Sizden öncekilere farz kılındığı gibi, oruç size de farz kılındı. Umulur ki sakınırsınız.",
  "quote1_source": "Kur'an, Bakara (2:183)",
  "quote2_ar": "مَنْ صَامَ رَمَضَانَ إِيمَانًا وَاحْتِسَابًا غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ",
  "quote2_text": "Kim, inanarak ve karşılığını Allah'tan bekleyerek Ramazan orucunu tutarsa, geçmiş günahları bağışlanır.",
  "quote2_source": "Sahih-i Buhari (38)",
  "quote3_ar": "لَيْلَةُ الْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ",
  "quote3_text": "Kadir gecesi bin aydan daha hayırlıdır.",
  "quote3_source": "Kur'an, Kadir (97:3)",
  "transcription": "Okunuşu",
  "translation": "Anlamı",
  "copied": "Kopyalandı",
  "duaSuhoorTitle": "Sahur Duası (Niyet)",
  "duaSuhoorArabic": "نَوَيْتُ أَنْ أَصُومَ صَوْمَ شَهْرِ رَمَضَانَ مِنَ الْفَجْرِ إِلَى الْمَغْرِبِ خَالِصًا لِلَّهِ تَعَالَى",
  "duaSuhoorTrans": "Neveytü en asûme savme şehri ramadâne minel fecri ilel mağribi hâlisan lillâhi teâlâ",
  "duaSuhoorTranslate": "Allah rızası için Ramazan ayının orucunu fecirden akşama kadar tutmaya niyet ettim.",
  "duaIftarTitle": "İftar Duası",
  "duaIftarArabic": "ذَهَبَ الظَّمَأُ وَابْتَلَّتِ الْعُرُوقُ وَثَبَتَ الْأَجْرُ إِنْ شَاءَ اللَّهُ",
  "duaIftarTrans": "Zehebez-zame'u vebtelletil-'urûku ve sebetel-ecru in şâallah",
  "duaIftarTranslate": "Susuzluk gitti, damarlar ıslandı ve inşallah mükafat kesinleşti.",
  "dua_qadr_title": "Kadir Gecesi Duası",
  "dua_qadr_ar": "اللَّهُمَّ إِنَّكَ عَفُوٌّ تُحِبُّ الْعَفْوَ فَاعْفُ عَنِّي",
  "dua_qadr_trans": "Allahümme inneke afüvvün tuhibbul-afve fa'fu annî",
  "dua_qadr_text": "Allah'ım! Sen affedicisin, affetmeyi seversin, beni de affet.",
  "dua_kursi_title": "Ayetü'l-Kürsi",
  "dua_kursi_ar": "اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَّهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَن ذَا الَّذِي يَشْفَعُ عِندَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِّنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ",
  "dua_kursi_trans": "Allâhü lâ ilâhe illâ hüvel hayyül kayyûm, lâ te'huzühu sinetün velâ nevm, lehu mâ fis-semâvâti ve mâ fil-ard, men zellezî yeşfeu 'indehû illâ bi-iznih, ya'lemü mâ beyne eydîhim ve mâ halfehüm, ve lâ yühîtûne bi-şey'im min 'ılmihî illâ bimâ şâ', vesi'a kürsiyyühüs-semâvâti vel-ard, ve lâ yeûdühû hıfzuhumâ, ve hüvel-'aliyyül-'azîm",
  "dua_kursi_text": "Allah! O'ndan başka ilah yoktur; O, hayydır, kayyûmdur. Kendisine ne uyuklama gelir ne de uyku. Göklerde ve yerdekilerin hepsi O'nundur. İzni olmadan O'nun katında kim şefaat edebilir? O, kullarının yaptıklarını ve yapacaklarını bilir. Onlar ise O'nun dilediği kadarından başka ilminden hiçbir şey kavrayamazlar. O'nun kürsüsü bütün gökleri ve yeri kucaklamıştır. Onları koruyup gözetmek O'na güç gelmez. O, yücedir, büyüktür.",
  "dua_istighfar_title": "Seyyidü'l-İstiğfar",
  "dua_istighfar_ar": "اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَهَ إِلَّا أَنْتَ خَلَقْتَنِي وَأَنَا عَبْدُكَ وَأَنَا عَلَى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطَعْتُ أَعُوذُ بِكَ مِنْ شَرِّ مَا صَنَعْتُ أَبُوءُ لَكَ بِنِعْمَتِكَ عَلَيَّ وَأَبُوءُ بِذَنْبِي فَاغْفِرْ لِي فَإِنَّهُ لَا يَغْفِرُ الذُّنُوبَ إِلَّا أَنْتَ",
  "dua_istighfar_trans": "Allahümme ente Rabbî lâ ilâhe illâ ente, halaktenî ve ene 'abduke, ve ene 'alâ 'ahdike ve va'dike mesteta'tu, eûzü bike min şerri mâ sana'tu, ebûu leke bi-ni'metike 'aleyye ve ebûu bi-zenbî, fağfirlî fe-innehû lâ yağfiruz-zünûbe illâ ente",
  "dua_istighfar_text": "Allah'ım! Sen benim Rabbimsin! Senden başka ilah yoktur. Beni Sen yarattın, ben Senin kulunum. Gücüm yettiğince verdiğim söz ve vaad üzereyim. Yaptıklarımın şerrinden Sana sığınırım. Üzerimdeki nimetini itiraf eder, günahımı da kabul ederim. Beni bağışla; çünkü günahları Senden başka kimse bağışlayamaz.",
  "dua_sadness_title": "Keder ve Üzüntü Duası",
  "dua_sadness_ar": "اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْهَمِّ وَالْحَزَنِ",
  "dua_sadness_trans": "Allahümme innî eûzü bike minel-hemmi vel-hazen",
  "dua_sadness_text": "Allah'ım! Kederden ve üzüntüden sana sığınırım.",
  "dua_morning_title": "Günlük Koruma",
  "dua_morning_ar": "بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ",
  "dua_morning_trans": "Bismillâhillezi lâ yedurru measmihi şey'ün fil-ardı ve lâ fis-semâ' ve hüves-semî'ul-'alîm",
  "dua_morning_text": "İsmiyle yerde ve gökte hiçbir şeyin zarar veremeyeceği Allah'ın adıyla. O, hakkıyla işitendir, hakkıyla bilendir."
}
