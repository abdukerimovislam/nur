  "duaSuhoorTitle": "Sahur Duası (Oruç Niyeti)",
  "duaSuhoorArabic": "نَوَيْتُ أَنْ أَصُومَ صَوْمَ شَهْرِ رَمَضَانَ مِنَ الْفَجْرِ إِلَى الْمَغْرِبِ خَالِصًا لِلَّهِ تَعَالَى",
  "duaSuhoorTranslit": "Neveytü en esûme savme şehri ramadâne mine'l-fecri ile'l-mağribi hâlisan lillâhi teâlâ.",
  "duaSuhoorTransl": "Allah rızası için Ramazan ayının orucunu fecirden akşama kadar tutmaya niyet ettim.",
  "duaSuhoorTrans": "Neveytü en esûme savme şehri ramadâne mine'l-fecri ile'l-mağribi hâlisan lillâhi teâlâ",
  "duaSuhoorTranslate": "Niyet ettim Allah rızası için yarınki Ramazan orucunu tutmaya.",

  "duaIftarTitle": "İftar Duası (Oruç Açma)",
  "duaIftarArabic": "اللَّهُمَّ اِنِّى لَكَ صُمْتُ وَبِكَ امَنْتُ وَعَليْكَ تَوَكَّلْتُ وَعَلى رِزْقِكَ اَفْطَرْتُ",
  "duaIftarTranslit": "Allahümme innî leke sumtü ve bike âmentü ve aleyke tevekkeltü ve alâ rızkıke eftartü.",
  "duaIftarTransl": "Allah'ım, senin rızan için oruç tuttum, sana inandım, sana güvendim ve senin rızkınla orucumu açtım.",
  "duaIftarTrans": "Zehebe'z-zamau vebtelleti'l-urûku ve sebete'l-ecru inşâallah",
  "duaIftarTranslate": "Susuzluk gitti, damarlar ıslandı ve inşallah mükafat kesinleşti.",

  "dua_qadr_title": "Kadir Gecesi Duası",
  "dua_qadr_ar": "اللَّهُمَّ إِنَّكَ عَفُوٌّ تُحِبُّ الْعَفْوَ فَاعْفُ عَنِّي",
  "dua_qadr_trans": "Allahümme inneke afüvvün tuhibbü'l-afve fa'fü annî",
  "dua_qadr_text": "Allah'ım, sen affedicisin, affetmeyi seversin, beni de affet.",

  "dua_kursi_title": "Ayet-el Kürsi",
  "dua_kursi_ar": "اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَّهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَن ذَا الَّذِي يَشْفَعُ عِندَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِّنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ",
  "dua_kursi_trans": "Allâhü lâ ilâhe illâ hüvel hayyül kayyûm, lâ te'huzühu sinetün velâ nevm...",
  "dua_kursi_text": "Allah, kendisinden başka hiçbir ilâh bulunmayandır. Diridir, kayyumdur. Onu ne bir uyuklama tutabilir, ne de bir uyku...",

  "dua_istighfar_title": "Seyyidül İstiğfar",
  "dua_istighfar_ar": "اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَهَ إِلَّا أَنْتَ خَلَقْتَنِي وَأَنَا عَبْدُكَ وَأَنَا عَلَى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطَعْتُ أَعُوذُ بِكَ مِنْ شَرِّ مَا صَنَعْتُ أَبُوءُ لَكَ بِنِعْمَتِكَ عَلَيَّ وَأَبُوءُ بِذَنْبِي فَاغْفِرْ لِي فَإِنَّهُ لَا يَغْفِرُ الذُّنُوبَ إِلَّا أَنْتَ",
  "dua_istighfar_trans": "Allahümme ente rabbî lâ ilâhe illâ ente halaktenî ve ene abdüke...",
  "dua_istighfar_text": "Allah'ım! Sen benim Rabbimsin! Senden başka ilâh yoktur. Beni sen yarattın. Ben senin kulunum...",

  "dua_sadness_title": "Sıkıntı ve Üzüntü Duası",
  "dua_sadness_ar": "اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْهَمِّ وَالْحَزَنِ",
  "dua_sadness_trans": "Allahümme innî eûzü bike mine'l-hemmi ve'l-hazen",
  "dua_sadness_text": "Allah'ım! Kederden ve üzüntüden sana sığınırım.",

  "dua_morning_title": "Günlük Korunma Duası",
  "dua_morning_ar": "بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ",
